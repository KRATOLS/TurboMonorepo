{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "NUXT_PUBLIC_DISABLED_PAGES"],
  "globalDependencies": [
    "**/.env.*local",
    "**/tsconfig.json",
    "**/eslint.config.mjs"
  ],
  "tasks": {
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "lint:fix": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build", "^lint"],
      "outputs": [".output/**"],
      "inputs": [
        "app/**",
        "components/**",
        "pages/**",
        "layouts/**",
        "plugins/**",
        "middleware/**",
        "server/**",
        "nuxt.config.ts",
        "tsconfig.json",
        "composables/**",
        "assets/*",
        "eslint.config.mjs"
      ]
    },
    "preview": {
      "cache": false,
      "persistent": true
    }
  }
}