{
  "name": "my-nuxt-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:web": "turbo build --filter=web",
    "build:admin": "turbo build --filter=admin",
    "dev:web": "turbo dev --filter=web",
    "dev:admin": "turbo dev --filter=admin",
    "preview": "turbo preview",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "lint:web": "turbo lint --filter=web",
    "lint:fix:web": "turbo lint:fix --filter=web"
  },
  "packageManager": "pnpm@10.34.1",
  "devDependencies": {
    "eslint": "^10.4.1",
    "turbo": "^2.9.15",
    "typescript": "^6.0.3"
  }
}
